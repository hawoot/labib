# ============================================================
#  labib — backend configuration
#  ------------------------------------------------------------
#  HOW TO USE:
#    1. Copy this file to ".env"   ->   cp .env.example .env
#    2. Fill in / uncomment what you need below.
#    3. Lines starting with "#" are OFF. Remove the "#" to turn on.
#  The ".env" file is git-ignored and never pushed. Keep it private.
# ============================================================


# ------------------------------------------------------------
#  1. APP
# ------------------------------------------------------------
APP_ENV=dev

# A long random secret. Generate one with:  openssl rand -hex 32
SECRET_KEY=change-me-to-a-long-random-string

# Which port the API is exposed on, on your VPS. Pick any free port
# you can open; this is the port you'll give me the URL for.
API_PORT=8000


# ------------------------------------------------------------
#  2. DATABASE
#  Default = Postgres (matches docker-compose.yml / deploy/vps.sh).
#  For an in-container deploy with no Postgres server, deploy/container.sh
#  sets DATABASE_URL to a local SQLite file automatically — leave it blank here.
# ------------------------------------------------------------
# DATABASE_URL=sqlite:////home/node/apps/labib/labib.db
POSTGRES_USER=labib
POSTGRES_PASSWORD=change-me-to-a-private-password
POSTGRES_DB=labib
POSTGRES_HOST=db
POSTGRES_PORT=5432


# ------------------------------------------------------------
#  3. THE AI BRAIN (LLM provider)
#  ------------------------------------------------------------
#  Almost every provider speaks the SAME "OpenAI-compatible" API,
#  so to switch you only change 3 lines: base URL, key, model.
#  Anthropic (Claude) is the exception -> use block 3E.
#
#  STEP 1: set LLM_PROVIDER  (openai_compatible OR anthropic)
#  STEP 2: uncomment exactly ONE block below and fill its key.
# ------------------------------------------------------------
LLM_PROVIDER=openai_compatible

# ---- 3A. OpenCode Zen ("Go") — ACTIVE default ----
#   Models: deepseek-v4-flash, deepseek-v4-pro, glm-5.1, kimi-k2.7-code, ...
LLM_BASE_URL=https://opencode.ai/zen/go/v1
LLM_API_KEY=sk-...your-opencode-zen-key...
LLM_MODEL=deepseek-v4-flash

# ---- 3B. OpenRouter (DeepSeek + 100s of others) ----
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_API_KEY=sk-or-...your-openrouter-key...
# LLM_MODEL=deepseek/deepseek-chat

# ---- 3C. DeepSeek (direct) ----
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_API_KEY=sk-...your-deepseek-key...
# LLM_MODEL=deepseek-chat

# ---- 3D. OpenAI ----
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-...your-openai-key...
# LLM_MODEL=gpt-4o

# ---- 3E. Groq (fast, free tier) ----
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_API_KEY=gsk_...your-groq-key...
# LLM_MODEL=llama-3.3-70b-versatile

# ---- 3F. Local Ollama (no key needed; runs on the host) ----
# LLM_BASE_URL=http://host.docker.internal:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=llama3.1

# ---- 3G. Anthropic / Claude  (set LLM_PROVIDER=anthropic above!) ----
#   For this block the base URL is fixed and LLM_BASE_URL is ignored.
# LLM_API_KEY=sk-ant-...your-anthropic-key...
# LLM_MODEL=claude-sonnet-4-6


# ------------------------------------------------------------
#  4. PUSH NOTIFICATIONS (Firebase Cloud Messaging)
#  ------------------------------------------------------------
#  This is the SECRET "send" credential — it lets the server push
#  notifications to phones. It is NOT a single API key: it's the whole
#  service-account JSON file you download from Firebase:
#
#     Firebase Console -> Project settings (gear icon)
#       -> "Service accounts" tab -> "Generate new private key"
#       -> downloads a file like  labib-190ad-xxxxxxxx.json
#
#  Leave BOTH lines below commented out to keep push DISABLED (the app still
#  runs; the "Send a test notification" button just says "not configured").
#  Turn ON exactly ONE of the two options:
#
#  ---- 4A. EASIEST: point at the file (recommended) ----
#    Put the downloaded JSON on the server (next to this .env is fine) and
#    give its path here. No quoting/escaping headaches.
# FIREBASE_CREDENTIALS_FILE=./firebase-service-account.json
#
#  ---- 4B. Or paste the whole JSON inline ----
#    Minify the file to a SINGLE line and wrap it in single quotes. Handy when
#    you can't drop a file on the host (e.g. a secrets UI that only takes text).
# FIREBASE_CREDENTIALS_JSON='{"type":"service_account","project_id":"labib-190ad", ...the rest of the file... }'

